{
  "pieces": [
    {
      "id": "row-row-your-boat",
      "title": "Row, Row, Row Your Boat",
      "composer": "Traditional",
      "year": "1852",
      "level": 1,
      "keySignature": "C",
      "timeSignature": "6/8",
      "tempo": 92,
      "description": "The classic children's round that first appeared in mid-19th-century American songbooks. Its gentle 6/8 rocking mirrors the pull of oars, making it a perfect first taste of compound time.",
      "skills": ["6/8 time", "rocking rhythm", "stepwise motion", "C position"],
      "teachingTips": "Feel two big beats per measure rather than counting all six — sway 'ONE-two-three, TWO-two-three' like a boat on water. The busy 'merrily' measures are just the C-major chord bounced up and down; keep those eighth notes light and even.",
      "measures": [
        { "rh": [{ "keys": ["C4"], "d": "q", "dots": 1 }, { "keys": ["C4"], "d": "q", "dots": 1 }], "lh": [{ "keys": ["C3"], "d": "h", "dots": 1 }] },
        { "rh": [{ "keys": ["C4"], "d": "q" }, { "keys": ["D4"], "d": "8" }, { "keys": ["E4"], "d": "q", "dots": 1 }], "lh": [{ "keys": ["C3"], "d": "h", "dots": 1 }] },
        { "rh": [{ "keys": ["E4"], "d": "q" }, { "keys": ["D4"], "d": "8" }, { "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "8" }], "lh": [{ "keys": ["C3"], "d": "q", "dots": 1 }, { "keys": ["G2"], "d": "q", "dots": 1 }] },
        { "rh": [{ "keys": ["G4"], "d": "h", "dots": 1 }], "lh": [{ "keys": ["C3"], "d": "h", "dots": 1 }] },
        { "rh": [{ "keys": ["C5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["G4"], "d": "8" }, { "keys": ["G4"], "d": "8" }, { "keys": ["G4"], "d": "8" }], "lh": [{ "keys": ["C3"], "d": "h", "dots": 1 }] },
        { "rh": [{ "keys": ["E4"], "d": "8" }, { "keys": ["E4"], "d": "8" }, { "keys": ["E4"], "d": "8" }, { "keys": ["C4"], "d": "8" }, { "keys": ["C4"], "d": "8" }, { "keys": ["C4"], "d": "8" }], "lh": [{ "keys": ["C3"], "d": "h", "dots": 1 }] },
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["F4"], "d": "8" }, { "keys": ["E4"], "d": "q" }, { "keys": ["D4"], "d": "8" }], "lh": [{ "keys": ["G2"], "d": "q", "dots": 1 }, { "keys": ["C3"], "d": "q", "dots": 1 }] },
        { "rh": [{ "keys": ["C4"], "d": "h", "dots": 1 }], "lh": [{ "keys": ["C2", "C3"], "d": "h", "dots": 1 }] }
      ]
    },
    {
      "id": "london-bridge",
      "title": "London Bridge Is Falling Down",
      "composer": "Traditional",
      "year": "Traditional",
      "level": 1,
      "keySignature": "C",
      "timeSignature": "4/4",
      "tempo": 108,
      "description": "An English nursery rhyme whose singing-game roots reach back centuries. The tune circles a tight five-note range, so the whole piece stays comfortably under one hand.",
      "skills": ["five-finger position", "repeated phrases", "quarter and half notes"],
      "teachingTips": "Notice that the 'falling down' phrase repeats three times on almost the same notes — learn it once and you nearly know the piece. Keep a steady walking pulse and let each half note ring fully before the next phrase.",
      "measures": [
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["A4"], "d": "q" }, { "keys": ["G4"], "d": "q" }, { "keys": ["F4"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "q" }, { "keys": ["G4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["D4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "h" }], "lh": [{ "keys": ["G2"], "d": "w" }] },
        { "rh": [{ "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "q" }, { "keys": ["G4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["A4"], "d": "q" }, { "keys": ["G4"], "d": "q" }, { "keys": ["F4"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "q" }, { "keys": ["G4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["D4"], "d": "q" }, { "keys": ["G4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["C4"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["C3"], "d": "h" }] },
        { "rh": [{ "keys": ["C4"], "d": "w" }], "lh": [{ "keys": ["C2", "C3"], "d": "w" }] }
      ]
    },
    {
      "id": "lightly-row",
      "title": "Lightly Row",
      "composer": "Traditional German",
      "year": "Traditional",
      "level": 1,
      "keySignature": "C",
      "timeSignature": "4/4",
      "tempo": 100,
      "description": "A German folk melody long used as an early teaching piece, familiar from the Suzuki repertoire. Its two matching halves and clear phrases make musical shape easy to hear and feel.",
      "skills": ["five-finger position", "phrase balance", "melodic contour"],
      "teachingTips": "Each phrase rises and then settles — lift slightly toward the top note and relax into the long note that ends it. Compare the first and second lines: they begin the same and only part ways at the very end.",
      "measures": [
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["E4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["F4"], "d": "q" }, { "keys": ["D4"], "d": "q" }, { "keys": ["D4"], "d": "h" }], "lh": [{ "keys": ["G2"], "d": "w" }] },
        { "rh": [{ "keys": ["C4"], "d": "q" }, { "keys": ["D4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["F4"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["G2"], "d": "h" }] },
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["G4"], "d": "q" }, { "keys": ["G4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["G4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["E4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "w" }] },
        { "rh": [{ "keys": ["F4"], "d": "q" }, { "keys": ["D4"], "d": "q" }, { "keys": ["D4"], "d": "h" }], "lh": [{ "keys": ["G2"], "d": "w" }] },
        { "rh": [{ "keys": ["C4"], "d": "q" }, { "keys": ["E4"], "d": "q" }, { "keys": ["G4"], "d": "q" }, { "keys": ["G4"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["G2"], "d": "h" }] },
        { "rh": [{ "keys": ["E4"], "d": "q" }, { "keys": ["C4"], "d": "q" }, { "keys": ["C4"], "d": "h" }], "lh": [{ "keys": ["C2", "C3"], "d": "w" }] }
      ]
    },
    {
      "id": "auld-lang-syne",
      "title": "Auld Lang Syne",
      "composer": "Traditional Scottish",
      "year": "1788",
      "level": 2,
      "keySignature": "C",
      "timeSignature": "4/4",
      "tempo": 88,
      "description": "Robert Burns set these words to an old Scots melody, and the world has sung it at every New Year since. Its gentle dotted rhythm and reaching phrases make it a warm study in expressive playing.",
      "skills": ["dotted quarter-eighth rhythm", "pickup notes", "phrase shaping", "key of C"],
      "teachingTips": "Each phrase begins on the final beat of the bar — count 'four, and' to launch cleanly into the downbeat. Play the dotted 'LONG-short' figures with an easy lilt, never rushed, and let the melody breathe at the top of each arch.",
      "measures": [
        { "rh": [{ "rest": true, "d": "h", "dots": 1 }, { "keys": ["G4"], "d": "q" }], "lh": [{ "rest": true, "d": "w" }] },
        { "rh": [{ "keys": ["C5"], "d": "q", "dots": 1 }, { "keys": ["C5"], "d": "8" }, { "keys": ["C5"], "d": "q" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["G2"], "d": "h" }] },
        { "rh": [{ "keys": ["D5"], "d": "q", "dots": 1 }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "q" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["C3"], "d": "h" }] },
        { "rh": [{ "keys": ["C5"], "d": "q", "dots": 1 }, { "keys": ["C5"], "d": "8" }, { "keys": ["E5"], "d": "q" }, { "keys": ["G5"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["E3"], "d": "h" }] },
        { "rh": [{ "keys": ["A5"], "d": "h", "dots": 1 }, { "keys": ["G5"], "d": "q" }], "lh": [{ "keys": ["F3"], "d": "h" }, { "keys": ["C3"], "d": "h" }] },
        { "rh": [{ "keys": ["A5"], "d": "q", "dots": 1 }, { "keys": ["G5"], "d": "8" }, { "keys": ["G5"], "d": "q" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["F3"], "d": "h" }, { "keys": ["C3"], "d": "h" }] },
        { "rh": [{ "keys": ["E5"], "d": "q", "dots": 1 }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "q" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["D3"], "d": "h" }] },
        { "rh": [{ "keys": ["D5"], "d": "q", "dots": 1 }, { "keys": ["C5"], "d": "8" }, { "keys": ["C5"], "d": "h" }], "lh": [{ "keys": ["C2", "C3"], "d": "w" }] }
      ]
    },
    {
      "id": "mountain-king",
      "title": "In the Hall of the Mountain King (theme)",
      "composer": "Edvard Grieg",
      "year": "1875",
      "level": 3,
      "keySignature": "Am",
      "timeSignature": "4/4",
      "tempo": 100,
      "description": "From Grieg's music for Ibsen's 'Peer Gynt', depicting the hero fleeing a cave of trolls. The creeping theme climbs the same few notes over and over, growing faster and louder — here presented at a steady stalking pace.",
      "skills": ["minor key", "staccato control", "repeated melodic cell", "even eighth notes"],
      "teachingTips": "Play the eighth notes short and sneaky, like tiptoeing footsteps. The whole tune is one small idea repeated a step higher each time, so lock the fingering of the first bar and simply shift it up. Keep the left-hand bass heavy and grounded beneath the creeping right hand.",
      "measures": [
        { "rh": [{ "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["A2"], "d": "h" }, { "keys": ["A2"], "d": "h" }] },
        { "rh": [{ "keys": ["D#5"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["D5"], "d": "q" }, { "rest": true, "d": "h" }], "lh": [{ "keys": ["E2"], "d": "h" }, { "keys": ["E2"], "d": "h" }] },
        { "rh": [{ "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["A5"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "h" }, { "keys": ["A2"], "d": "h" }] },
        { "rh": [{ "keys": ["G#5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["G#5"], "d": "q" }, { "rest": true, "d": "h" }], "lh": [{ "keys": ["E2"], "d": "h" }, { "keys": ["E2"], "d": "h" }] },
        { "rh": [{ "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["A2"], "d": "h" }, { "keys": ["A2"], "d": "h" }] },
        { "rh": [{ "keys": ["E5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["A4"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["A4"], "d": "q" }], "lh": [{ "keys": ["A2"], "d": "h" }, { "keys": ["A2"], "d": "h" }] },
        { "rh": [{ "keys": ["B4"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["D#5"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["E5"], "d": "8" }, { "keys": ["D#5"], "d": "8" }, { "keys": ["E5"], "d": "8" }], "lh": [{ "keys": ["E2"], "d": "h" }, { "keys": ["E2"], "d": "h" }] },
        { "rh": [{ "keys": ["A4"], "d": "h" }, { "keys": ["A4"], "d": "h" }], "lh": [{ "keys": ["A1", "A2"], "d": "w" }] }
      ]
    },
    {
      "id": "morning-mood",
      "title": "Morning Mood (opening)",
      "composer": "Edvard Grieg",
      "year": "1875",
      "level": 3,
      "keySignature": "G",
      "timeSignature": "4/4",
      "tempo": 72,
      "description": "The sunrise that opens Grieg's 'Peer Gynt' Suite, passed between flute and oboe over shimmering strings. Its gently rocking pentatonic melody is one of the most recognizable dawns in all of music.",
      "skills": ["legato phrasing", "pentatonic melody", "key of G", "expressive dynamics"],
      "teachingTips": "Shape the melody like a slow breath in and out — rise softly toward each high note and ease back down. The tune is entirely built from a five-note pattern that keeps folding back on itself, so listen for how each phrase gently answers the last. Remember every F is F-sharp.",
      "measures": [
        { "rh": [{ "keys": ["D5"], "d": "q" }, { "keys": ["E5"], "d": "q" }, { "keys": ["D5"], "d": "q" }, { "keys": ["B4"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["D3"], "d": "h" }] },
        { "rh": [{ "keys": ["A4"], "d": "q" }, { "keys": ["B4"], "d": "q" }, { "keys": ["D5"], "d": "h" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["D3"], "d": "h" }] },
        { "rh": [{ "keys": ["E5"], "d": "q" }, { "keys": ["D5"], "d": "q" }, { "keys": ["B4"], "d": "q" }, { "keys": ["A4"], "d": "q" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["E3"], "d": "h" }] },
        { "rh": [{ "keys": ["G4"], "d": "h", "dots": 1 }, { "keys": ["A4"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["D3"], "d": "h" }] },
        { "rh": [{ "keys": ["B4"], "d": "q" }, { "keys": ["A4"], "d": "q" }, { "keys": ["B4"], "d": "q" }, { "keys": ["D5"], "d": "q" }], "lh": [{ "keys": ["G2"], "d": "h" }, { "keys": ["B2"], "d": "h" }] },
        { "rh": [{ "keys": ["E5"], "d": "q" }, { "keys": ["D5"], "d": "q" }, { "keys": ["B4"], "d": "h" }], "lh": [{ "keys": ["C3"], "d": "h" }, { "keys": ["A2"], "d": "h" }] },
        { "rh": [{ "keys": ["A4"], "d": "q" }, { "keys": ["B4"], "d": "q" }, { "keys": ["D5"], "d": "q" }, { "keys": ["E5"], "d": "q" }], "lh": [{ "keys": ["D3"], "d": "h" }, { "keys": ["D3"], "d": "h" }] },
        { "rh": [{ "keys": ["G4"], "d": "w" }], "lh": [{ "keys": ["G2", "G3"], "d": "w" }] }
      ]
    },
    {
      "id": "habanera-carmen",
      "title": "Habanera from Carmen (theme)",
      "composer": "Georges Bizet",
      "year": "1875",
      "level": 4,
      "keySignature": "Am",
      "timeSignature": "4/4",
      "tempo": 92,
      "description": "Carmen's seductive entrance aria, built on a slinking chromatic line that slides downward one half-step at a time. Bizet borrowed the swaying habanera dance rhythm, giving the melody its irresistible pull.",
      "skills": ["chromatic melody", "syncopated accompaniment", "minor key", "expressive rubato"],
      "teachingTips": "Practice the chromatic descent slowly, naming each half step so the fingers learn the tight downward slide. Keep the left-hand habanera pattern steady and slightly detached — it is the dance floor under the singer's line. Let the melody lean and linger for a touch of Carmen's swagger.",
      "measures": [
        { "rh": [{ "keys": ["E5"], "d": "q" }, { "keys": ["D#5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["C#5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["A4"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }] },
        { "rh": [{ "keys": ["A4"], "d": "q" }, { "keys": ["A4"], "d": "8" }, { "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "q" }, { "keys": ["A4"], "d": "8" }, { "keys": ["G#4"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }] },
        { "rh": [{ "keys": ["E5"], "d": "q" }, { "keys": ["D#5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["C#5"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["A4"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }] },
        { "rh": [{ "keys": ["A4"], "d": "q" }, { "keys": ["A4"], "d": "8" }, { "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "q" }, { "keys": ["C5"], "d": "8" }, { "keys": ["A4"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }] },
        { "rh": [{ "keys": ["E4"], "d": "8" }, { "keys": ["F4"], "d": "8" }, { "keys": ["G#4"], "d": "8" }, { "keys": ["A4"], "d": "8" }, { "keys": ["B4"], "d": "8" }, { "keys": ["C5"], "d": "8" }, { "keys": ["D5"], "d": "8" }, { "keys": ["E5"], "d": "8" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }] },
        { "rh": [{ "keys": ["A4"], "d": "h" }, { "rest": true, "d": "h" }], "lh": [{ "keys": ["A2"], "d": "8" }, { "rest": true, "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["E3", "A3", "C4"], "d": "8" }, { "keys": ["A1", "A2"], "d": "h" }] }
      ]
    }
  ]
}
